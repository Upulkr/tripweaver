{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python",
      "config": {
        "buildCommand": "python -m prisma generate --schema=api/prisma/schema.prisma"
      }
    }
  ],
  "routes": [
    {
      "src": "/(api/.*|docs.*|openapi.json)",
      "dest": "api/main.py"
    }
  ]
}
